# Copy to themis.yaml and adjust. Sensitive values (DSN, passwords, API keys)
# must be set via environment variables — never committed in themis.yaml.
#
#   cp themis.yaml.example themis.yaml
#   export THEMIS_DATABASE_DSN="postgres://themis:themis-dev-password@localhost:5432/themis?sslmode=disable"
#   ./bin/themis

server:
  port: 8080
  read_timeout: 30s
  write_timeout: 30s

database:
  dsn: ""          # required: set THEMIS_DATABASE_DSN
  max_pool_size: 20

worker:
  pool_size: 10
  max_retry: 3

upload:
  max_size_bytes: 52428800   # 50 MiB
  timeout: 5m

nvd:
  api_key: ""      # override with THEMIS_NVD_API_KEY
  poll_interval: 6h
  # rate_limit_rps: 0   # 0 = auto, NVD-compliant (≈1.5/s with an API key, ≈0.15/s
  #                     # without). Set a positive value to override. NVD's limits
  #                     # are 50 req / 30s with a key, 5 req / 30s without; a higher
  #                     # rate trips NVD's Cloudflare throttle (HTTP 503).

smtp:
  host: ""         # override with THEMIS_SMTP_HOST
  port: 587
  # password: set via THEMIS_SMTP_PASSWORD only

teams:
  # webhook_url: set via THEMIS_TEAMS_WEBHOOK_URL only

trust:
  default_policy: standard   # strict | standard | permissive

# --- Phase 2a: threat signal feeds (implemented) ---
# Poll intervals use Go duration strings (e.g. 24h, 12h). Env vars override YAML.

epsskev:
  # FIRST.org EPSS scores (gzip CSV) — feeds Layer 1 rules and risk score V2 EPSS adjustment
  epss_url: https://epss.cyentia.com/epss_scores-current.csv.gz
  # CISA Known Exploited Vulnerabilities catalog — sets kev_listed on matching findings
  kev_url: https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
  poll_interval: 24h

exploitdb:
  # Public ExploitDB mirror — populates exploit_records; drives ExploitPublic Layer 1 rule
  csv_url: https://gitlab.com/exploit-database/exploitdb/-/raw/main/files_exploits.csv
  poll_interval: 24h

vexfeed:
  # CR-4 feed taxonomy: true VEX (overlay) is separated from advisory / OSV feeds (correlation).
  rhel_vex_url: https://security.access.redhat.com/data/csaf/v2/vex/          # Red Hat CSAF VEX → overlay
  rhel_csaf_url: https://security.access.redhat.com/data/csaf/v2/advisories/  # Red Hat advisories → rpm correlation
  # rhel_url:  (deprecated alias for rhel_csaf_url; kept one release)
  alpine_osv_url: https://storage.googleapis.com/osv-vulnerabilities/Alpine/all.zip   # apk correlation
  rocky_osv_url: https://storage.googleapis.com/osv-vulnerabilities/Rocky%20Linux/all.zip  # rpm correlation
  wolfi_osv_url: https://packages.wolfi.dev/os/security.json                 # apk correlation
  poll_interval: 24h
  # Feed registry (optional): a delta list merged over the built-in defaults by name.
  # Built-in names: rhel-vex (overlay); rhel-csaf, alpine, rocky, wolfi (correlation).
  # Add a custom feed, override a built-in's fields, or disable one (enabled: false).
  # feeds:
  #   - name: rocky            # disable a built-in by name
  #     enabled: false
  #   - name: my-distro        # add a custom correlation feed
  #     type: zip-osv          # url | zip-osv | csaf-dir
  #     class: correlation     # correlation (default) | overlay
  #     url: https://example.com/osv/all.zip
  #     ecosystem: mydistro    # informational label
  #     enabled: true
  #   - name: my-url-feed
  #     type: url
  #     kind: osv              # for type=url: csaf | osv (default osv)
  #     url: https://example.com/security.json

intelligence:
  # Unique Customer count at which blast-radius score multiplier caps (default 10 → 2.0×)
  blast_radius_cap: 10

log:
  level: info   # override with THEMIS_LOG_LEVEL (debug|info|warn|error)

# --- Phase 2b (config wired; GHSA adapter not implemented yet) ---
# github:
#   token: ""   # set THEMIS_GITHUB_TOKEN for GHSA rate limits when Phase 2b ships
